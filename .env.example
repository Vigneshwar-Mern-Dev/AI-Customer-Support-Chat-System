# ===========================================
# AI Customer Support Chat System — .env
# ===========================================

# Database — SQLite for local dev (zero setup)
# For Vercel: use Neon free tier → postgresql://...
DATABASE_URL="file:./dev.db"

# NextAuth — REQUIRED
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OpenAI — OPTIONAL (app works without this using smart mock AI)
# Get free key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Admin seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL="admin@support.com"
ADMIN_PASSWORD="Admin@123"

# Optional: Google OAuth (leave empty to disable)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
